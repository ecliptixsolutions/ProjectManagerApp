@model ProjectManagerApp.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

@if (User.Identity?.IsAuthenticated != true)
{
    <div class="text-center py-5">
        <h1 class="display-4 fw-bold">Project Management System</h1>
        <p class="lead text-muted">Manage projects, employees, finances, and payroll.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg mt-3 px-5">Get Started</a>
    </div>
    return;
}

<div class="page-header">
    <h1>Dashboard</h1>
    <p>Overview of your business operations</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#eef2ff;color:#4f46e5"><i class="fas fa-folder"></i></div>
            <div class="stat-label">Total Projects</div>
            <div class="stat-value">@Model.TotalProjects</div>
            <div class="stat-change text-muted">@Model.ActiveProjects active &middot; @Model.CompletedProjects completed</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#ecfdf5;color:#10b981"><i class="fas fa-users"></i></div>
            <div class="stat-label">Employees</div>
            <div class="stat-value">@Model.TotalEmployees</div>
            <div class="stat-change text-muted">@Model.ActiveEmployees active</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#f0f9ff;color:#06b6d4"><i class="fas fa-coins"></i></div>
            <div class="stat-label">Total Revenue</div>
            <div class="stat-value">@Model.TotalRevenue.ToString("C0")</div>
            <div class="stat-change text-muted">Across all projects</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:@(Model.NetProfit >= 0 ? "#fffbeb;color:#f59e0b" : "#fef2f2;color:#ef4444")"><i class="fas fa-chart-line"></i></div>
            <div class="stat-label">Net Profit</div>
            <div class="stat-value @(Model.NetProfit >= 0 ? "" : "text-danger")">@Model.NetProfit.ToString("C0")</div>
            <div class="stat-change @(Model.NetProfit >= 0 ? "text-success" : "text-danger")">
                <i class="fas fa-@(Model.NetProfit >= 0 ? "arrow-up" : "arrow-down") me-1"></i>
                Revenue - Expenses - Salary
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-chart-bar me-2 text-primary"></i>Revenue vs Expenses</span>
            </div>
            <div class="card-body">
                <canvas class="chart-revenue-expense" height="250"
                        data-labels='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentProjects.Select(p => p.Name)))'
                        data-revenue='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentProjects.Select(p => p.Revenues.Sum(r => r.Amount))))'
                        data-expense='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentProjects.Select(p => p.Expenses.Sum(e => e.Amount) + p.SalaryPayments.Sum(s => s.NetSalary))))'>
                </canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-chart-pie me-2 text-primary"></i>Project Status</div>
            <div class="card-body">
                <canvas class="chart-project-status" height="250"
                        data-labels='["New","In Progress","Completed","On Hold","Cancelled"]'
                        data-values='[@Model.PendingProjects,@Model.ActiveProjects,@Model.CompletedProjects,0,0]'>
                </canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-folder-open me-2 text-primary"></i>Recent Projects</span>
                <a asp-controller="Finance" asp-action="Projects" class="btn btn-sm btn-soft-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @foreach (var p in Model.RecentProjects)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@p.Name</strong>
                                <br><small class="text-muted">@p.ClientName</small>
                            </div>
                            <span class="badge @(p.Status == "Completed" ? "bg-success" : p.Status == "InProgress" ? "bg-primary" : "bg-secondary")">@p.Status</span>
                        </div>
                    }
                    @if (!Model.RecentProjects.Any())
                    {
                        <div class="list-group-item text-muted">No projects yet.</div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-clock me-2 text-primary"></i>Recent Activity</span>
                <a asp-controller="AuditLogs" asp-action="Index" class="btn btn-sm btn-soft-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="activity-timeline">
                    @foreach (var log in Model.RecentAuditLogs)
                    {
                        <div class="activity-item">
                            <strong>@log.UserName</strong> @log.ActionType <span class="badge bg-light text-dark">@log.EntityType</span>
                            <div class="activity-time">@log.Timestamp.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</div>
                        </div>
                    }
                    @if (!Model.RecentAuditLogs.Any())
                    {
                        <div class="text-muted small">No recent activity.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-clipboard-check me-2 text-primary"></i>Recent Work Updates</span>
        <a asp-controller="DailyWork" asp-action="Index" class="btn btn-sm btn-soft-primary">View All</a>
    </div>
    <div class="card-body p-0">
        <div class="list-group list-group-flush">
            @foreach (var w in Model.RecentWorkUpdates)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@w.Employee?.FullName</strong> on <strong>@w.Project?.Name</strong>
                        <br><small class="text-muted">@w.WorkDescription?.Substring(0, Math.Min(80, w.WorkDescription?.Length ?? 0))</small>
                    </div>
                    <span class="badge bg-light text-dark">@w.HoursWorked hrs</span>
                </div>
            }
            @if (!Model.RecentWorkUpdates.Any())
            {
                <div class="list-group-item text-muted">No work updates yet.</div>
            }
        </div>
    </div>
</div>
