@model IEnumerable<ProjectManagerApp.Models.ProjectAssignment>

@{
    ViewData["Title"] = "All Assignments";
    var projects = ViewBag.Projects as IEnumerable<ProjectManagerApp.Models.Project>;
}

<h1>All Project Assignments</h1>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <select name="projectId" class="form-select" onchange="this.form.submit()">
            <option value="">All Projects</option>
            @foreach (var p in projects ?? Enumerable.Empty<ProjectManagerApp.Models.Project>())
            {
                <option value="@p.Id" selected="@(Context.Request.Query["projectId"].ToString() == p.Id.ToString())">@p.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <a asp-action="Assignments" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Employee</th>
                <th>Project</th>
                <th>Role</th>
                <th>Assigned By</th>
                <th>Assigned Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.Employee?.FullName</td>
                    <td>@a.Project?.Name</td>
                    <td>@a.Role</td>
                    <td>@a.AssignedByUser?.UserName</td>
                    <td>@a.AssignmentDate.ToShortDateString()</td>
                    <td><span class="badge @(a.Status == "Active" ? "bg-success" : "bg-secondary")">@a.Status</span></td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No assignments found.</td></tr>
            }
        </tbody>
    </table>
</div>
