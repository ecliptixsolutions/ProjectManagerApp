@model ProjectManagerApp.ViewModels.EmployeeDetailsViewModel

@{
    ViewData["Title"] = "Employee Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 mb-1">@Model.Employee.FullName</h1>
        <p class="text-muted mb-0">
            <span class="badge bg-secondary">@Model.Employee.EmployeeId</span>
            @Model.Employee.Designation - @Model.Employee.Department
        </p>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Employee.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white"><h5 class="mb-0">Basic Information</h5></div>
            <div class="card-body">
                <table class="table table-sm">
                    <tr><th>Name</th><td>@Model.Employee.FullName</td></tr>
                    <tr><th>Employee ID</th><td>@Model.Employee.EmployeeId</td></tr>
                    <tr><th>Email</th><td>@Model.Employee.Email</td></tr>
                    <tr><th>Phone</th><td>@Model.Employee.Phone</td></tr>
                    <tr><th>Address</th><td>@Model.Employee.Address</td></tr>
                    <tr><th>Department</th><td>@Model.Employee.Department</td></tr>
                    <tr><th>Designation</th><td>@Model.Employee.Designation</td></tr>
                    <tr><th>Joining Date</th><td>@Model.Employee.JoinedDate.ToShortDateString()</td></tr>
                    <tr><th>Employment Type</th><td>@Model.Employee.EmploymentType</td></tr>
                    <tr><th>Status</th>
                        <td><span class="badge @(Model.Employee.Status == "Active" ? "bg-success" : "bg-secondary")">@Model.Employee.Status</span></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white"><h5 class="mb-0">Salary & Bank Details</h5></div>
            <div class="card-body">
                <table class="table table-sm">
                    <tr><th>Monthly Salary</th><td>@Model.Employee.SalaryAmount.ToString("C2")</td></tr>
                    <tr><th>Salary Type</th><td>@Model.Employee.SalaryType</td></tr>
                    <tr><th>Total Paid</th><td><strong>@Model.TotalPaid.ToString("C2")</strong></td></tr>
                    <tr><th>Bank Name</th><td>@Model.Employee.BankName</td></tr>
                    <tr><th>Account Number</th><td>@Model.Employee.AccountNumber</td></tr>
                    <tr><th>IFSC Code</th><td>@Model.Employee.IfscCode</td></tr>
                    <tr><th>UPI ID</th><td>@Model.Employee.UpiId</td></tr>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Login Account</h5>
            </div>
            <div class="card-body">
                @if (Model.Employee.AppUserId.HasValue)
                {
                    <p class="text-success">Login account exists</p>
                    <form asp-action="ResetPassword" method="post" class="row g-2">
                        <input type="hidden" name="id" value="@Model.Employee.Id" />
                        <div class="col-md-8">
                            <input type="password" name="newPassword" class="form-control" placeholder="New password" required />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-warning">Reset Password</button>
                        </div>
                    </form>
                }
                else
                {
                    <p class="text-warning">No login account</p>
                    <form asp-action="CreateLogin" method="post" class="row g-2">
                        <input type="hidden" name="id" value="@Model.Employee.Id" />
                        <div class="col-md-4">
                            <input type="text" name="username" class="form-control" placeholder="Username" required />
                        </div>
                        <div class="col-md-4">
                            <input type="password" name="password" class="form-control" placeholder="Password" required />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-success">Create Login</button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h5 class="mb-0">Assigned Projects</h5></div>
            <div class="card-body">
                @if (Model.Assignments.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var a in Model.Assignments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @a.Project?.Name
                                <span class="badge bg-info">@a.Role</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">No projects assigned.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white"><h5 class="mb-0">Salary Payment History</h5></div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Month</th>
                    <th>Basic</th>
                    <th>Bonus</th>
                    <th>Deduction</th>
                    <th>Net Salary</th>
                    <th>Payment Date</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model.Employee.SalaryPayments.OrderByDescending(s => s.PaymentDate))
                {
                    <tr>
                        <td>@payment.Month</td>
                        <td>@payment.BasicSalary.ToString("C2")</td>
                        <td>@payment.Bonus.ToString("C2")</td>
                        <td>@payment.Deduction.ToString("C2")</td>
                        <td><strong>@payment.NetSalary.ToString("C2")</strong></td>
                        <td>@payment.PaymentDate.ToShortDateString()</td>
                        <td>
                            <span class="badge @(payment.PaymentStatus == "Paid" ? "bg-success" : "bg-warning text-dark")">@payment.PaymentStatus</span>
                        </td>
                        <td>
                            <form asp-action="DeleteSalaryPayment" method="post">
                                <input type="hidden" name="id" value="@payment.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this payment?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Employee.SalaryPayments.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-3">No salary payments recorded.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white"><h5 class="mb-0">Record Salary Payment</h5></div>
    <div class="card-body">
        <form asp-action="AddSalaryPayment" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="EmployeeId" value="@Model.Employee.Id" />

            <div class="col-md-3">
                <label class="form-label">Month</label>
                <input type="text" name="Month" class="form-control" placeholder="e.g., 2024-01" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Basic Salary</label>
                <input type="number" step="0.01" name="BasicSalary" class="form-control" value="@Model.Employee.SalaryAmount" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Bonus</label>
                <input type="number" step="0.01" name="Bonus" class="form-control" value="0" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Deduction</label>
                <input type="number" step="0.01" name="Deduction" class="form-control" value="0" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Net Salary</label>
                <input type="number" step="0.01" name="NetSalary" class="form-control" value="@Model.Employee.SalaryAmount" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Payment Date</label>
                <input type="date" name="PaymentDate" class="form-control" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="PaymentStatus" class="form-select">
                    <option value="Pending">Pending</option>
                    <option value="Paid">Paid</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Project (Optional)</label>
                <select name="ProjectId" class="form-select">
                    <option value="">(none)</option>
                    @foreach (var project in Model.Projects)
                    {
                        <option value="@project.Id">@project.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Notes</label>
                <input name="Notes" class="form-control" />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Record Payment</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white"><h5 class="mb-0">Work History</h5></div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Project</th>
                    <th>Work Description</th>
                    <th>Hours</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in Model.WorkUpdates)
                {
                    <tr>
                        <td>@w.WorkDate.ToShortDateString()</td>
                        <td>@w.Project?.Name</td>
                        <td>@w.WorkDescription</td>
                        <td>@w.HoursWorked</td>
                        <td>@w.Remarks</td>
                    </tr>
                }
                @if (!Model.WorkUpdates.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No work updates.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
