@model IEnumerable<ProjectManagerApp.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Employees</h1>
        <p>Manage your workforce</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Add Employee</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover datatable mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Designation</th>
                    <th>Department</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Salary</th>
                    <th>Login</th>
                    <th style="width:180px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employee in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@employee.EmployeeId</span></td>
                        <td><strong>@employee.FullName</strong></td>
                        <td>@employee.Designation</td>
                        <td>@employee.Department</td>
                        <td>@employee.Email</td>
                        <td>
                            <span class="badge @(employee.Status == "Active" ? "bg-success" : "bg-secondary")">@employee.Status</span>
                        </td>
                        <td>@employee.SalaryAmount.ToString("C0")</td>
                        <td>
                            @if (employee.AppUserId.HasValue)
                            {
                                <span class="badge bg-success"><i class="fas fa-check"></i> Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark"><i class="fas fa-times"></i> No</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details" asp-route-id="@employee.Id" class="btn btn-outline-secondary" title="View"><i class="fas fa-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-outline-primary" title="Edit"><i class="fas fa-edit"></i></a>
                                <form asp-action="Delete" asp-route-id="@employee.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger" title="Deactivate" onclick="return confirm('Deactivate this employee?')"><i class="fas fa-user-slash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No employees found. <a asp-action="Create">Add one</a></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
