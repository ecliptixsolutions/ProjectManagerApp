@model IEnumerable<ProjectManagerApp.Models.SalaryPayment>

@{
    ViewData["Title"] = "Salary Report";
    var months = ViewBag.Months as List<string>;
}

<h1>Salary Report</h1>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <select name="month" class="form-select" onchange="this.form.submit()">
            <option value="">All Months</option>
            @if (months != null)
            {
                @foreach (var m in months)
                {
                    <option value="@m" selected="@(Context.Request.Query["month"].ToString() == m)">@m</option>
                }
            }
        </select>
    </div>
    <div class="col-md-4">
        <select name="status" class="form-select" onchange="this.form.submit()">
            <option value="">All Status</option>
            <option value="Pending" selected="@(Context.Request.Query["status"].ToString() == "Pending")">Pending</option>
            <option value="Paid" selected="@(Context.Request.Query["status"].ToString() == "Paid")">Paid</option>
            <option value="Cancelled" selected="@(Context.Request.Query["status"].ToString() == "Cancelled")">Cancelled</option>
        </select>
    </div>
    <div class="col-md-4">
        <a asp-action="Salaries" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Employee</th>
                <th>Month</th>
                <th>Basic</th>
                <th>Bonus</th>
                <th>Deduction</th>
                <th>Net Salary</th>
                <th>Payment Date</th>
                <th>Status</th>
                <th>Project</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.Employee?.FullName</td>
                    <td>@s.Month</td>
                    <td>@s.BasicSalary.ToString("C2")</td>
                    <td class="text-success">@s.Bonus.ToString("C2")</td>
                    <td class="text-danger">@s.Deduction.ToString("C2")</td>
                    <td><strong>@s.NetSalary.ToString("C2")</strong></td>
                    <td>@s.PaymentDate.ToShortDateString()</td>
                    <td>
                        <span class="badge @(s.PaymentStatus == "Paid" ? "bg-success" : s.PaymentStatus == "Pending" ? "bg-warning text-dark" : "bg-secondary")">
                            @s.PaymentStatus
                        </span>
                    </td>
                    <td>@s.Project?.Name</td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="9" class="text-center text-muted py-4">No salary records found.</td></tr>
            }
        </tbody>
        <tfoot class="table-light">
            <tr>
                <th colspan="5" class="text-end">Total:</th>
                <th>@Model.Sum(s => s.NetSalary).ToString("C2")</th>
                <th colspan="3"></th>
            </tr>
        </tfoot>
    </table>
</div>
