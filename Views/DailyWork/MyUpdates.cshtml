@{
    ViewData["Title"] = "My Work Updates";
    var employee = ViewBag.Employee as ProjectManagerApp.Models.Employee;
    var updates = Model as IEnumerable<ProjectManagerApp.Models.DailyWorkUpdate>;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>My Work Updates</h1>
        <p>Track your daily contributions</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Log Work</a>
</div>

@if (updates != null && updates.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card text-center">
                <div class="stat-label">Total Updates</div>
                <div class="stat-value">@updates.Count()</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card text-center">
                <div class="stat-label">Total Hours</div>
                <div class="stat-value">@updates.Sum(u => u.HoursWorked).ToString("F1")</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card text-center">
                <div class="stat-label">Last Update</div>
                <div class="stat-value" style="font-size:1rem">@updates.First().WorkDate.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover datatable mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Project</th>
                    <th>Work Description</th>
                    <th>Hours</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                @if (updates != null)
                {
                    @foreach (var w in updates)
                    {
                        <tr>
                            <td>@w.WorkDate.ToShortDateString()</td>
                            <td><strong>@w.Project?.Name</strong></td>
                            <td>@w.WorkDescription</td>
                            <td><span class="badge bg-light text-dark">@w.HoursWorked hrs</span></td>
                            <td>@w.Remarks</td>
                        </tr>
                    }
                }
                @if (updates == null || !updates.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No work logged yet. <a asp-action="Create">Log your first update</a></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
