@model ProjectManagerApp.Models.DailyWorkUpdate

@{
    ViewData["Title"] = "Log Work";
    var employee = ViewBag.Employee as ProjectManagerApp.Models.Employee;
    var projects = ViewBag.Projects as IEnumerable<ProjectManagerApp.Models.Project>;
}

<div class="page-header">
    <h1>Log Daily Work</h1>
    <p>Record your work for today</p>
</div>

@if (employee == null)
{
    <div class="alert alert-warning"><i class="fas fa-exclamation-triangle me-2"></i>No employee profile linked to your account. Contact admin.</div>
    return;
}

@if (projects == null || !projects.Any())
{
    <div class="alert alert-info"><i class="fas fa-info-circle me-2"></i>No projects assigned to you yet. Contact admin for assignments.</div>
    return;
}

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post" class="row g-3">
                    <div asp-validation-summary="All" class="text-danger"></div>
                    <input type="hidden" asp-for="EmployeeId" value="@employee.Id" />

                    <div class="col-md-6">
                        <label asp-for="ProjectId" class="form-label required">Project</label>
                        <select asp-for="ProjectId" class="form-select" required>
                            <option value="">Select project...</option>
                            @foreach (var p in projects)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                        <span asp-validation-for="ProjectId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="WorkDate" class="form-label required">Date</label>
                        <input asp-for="WorkDate" class="form-control" type="date" />
                        <span asp-validation-for="WorkDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="HoursWorked" class="form-label required">Hours</label>
                        <input asp-for="HoursWorked" class="form-control" type="number" step="0.5" min="0.5" max="24" />
                        <span asp-validation-for="HoursWorked" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="WorkDescription" class="form-label required">Work Description</label>
                        <textarea asp-for="WorkDescription" class="form-control" rows="4" required></textarea>
                        <span asp-validation-for="WorkDescription" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Remarks" class="form-label">Remarks</label>
                        <textarea asp-for="Remarks" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane me-1"></i>Submit</button>
                        <a asp-action="MyUpdates" class="btn btn-outline-secondary"><i class="fas fa-times me-1"></i>Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
