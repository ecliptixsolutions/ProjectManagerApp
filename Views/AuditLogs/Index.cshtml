@model IEnumerable<ProjectManagerApp.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Logs";
    var actionTypes = ViewBag.ActionTypes as List<string>;
    var modules = ViewBag.Modules as List<string>;
}

<div class="page-header">
    <h1>Audit Logs</h1>
    <p>Track all system activities</p>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" name="search" class="form-control" placeholder="Search user, entity, metadata..." value="@(Context.Request.Query["search"].ToString())" />
        </div>
    </div>
    <div class="col-md-3">
        <select name="actionType" class="form-select" onchange="this.form.submit()">
            <option value="">All Actions</option>
            @if (actionTypes != null)
            {
                @foreach (var a in actionTypes)
                {
                    <option value="@a" selected="@(Context.Request.Query["actionType"].ToString() == a)">@a</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="module" class="form-select" onchange="this.form.submit()">
            <option value="">All Modules</option>
            @if (modules != null)
            {
                @foreach (var m in modules.OrderBy(x => x))
                {
                    <option value="@m" selected="@(Context.Request.Query["module"].ToString() == m)">@m</option>
                }
            }
        </select>
    </div>
    <div class="col-md-2">
        <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="fas fa-times me-1"></i>Clear</a>
    </div>
</form>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover datatable mb-0">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>User</th>
                    <th>Role</th>
                    <th>Action</th>
                    <th>Module</th>
                    <th>Entity</th>
                    <th>Details</th>
                    <th>IP</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td class="text-nowrap small">@log.Timestamp.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</td>
                        <td>@(log.UserName ?? log.User?.UserName)</td>
                        <td><span class="badge bg-light text-dark">@log.UserRole</span></td>
                        <td>
                            <span class="badge @(log.ActionType == "Create" ? "bg-success" : log.ActionType == "Update" ? "bg-primary" : log.ActionType == "Delete" || log.ActionType == "Deactivate" ? "bg-danger" : log.ActionType == "Login" ? "bg-info" : log.ActionType == "Logout" ? "bg-secondary" : "bg-warning text-dark")">
                                @log.ActionType
                            </span>
                        </td>
                        <td>@log.ModuleName</td>
                        <td>@log.EntityType</td>
                        <td class="small">@log.Metadata</td>
                        <td class="text-muted small">@log.IpAddress</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No audit logs found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
