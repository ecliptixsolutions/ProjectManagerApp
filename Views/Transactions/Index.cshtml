@model System.Collections.IEnumerable

@{
    var type = ViewBag.TypeFilter as string;
    ViewData["Title"] = string.IsNullOrEmpty(type) ? "Revenue" : "Expenses";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p>Track all @(string.IsNullOrEmpty(type) ? "revenue" : "expense") transactions</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="AddRevenue" class="btn btn-success"><i class="fas fa-plus me-1"></i>Add Revenue</a>
        <a asp-action="AddExpense" class="btn btn-danger"><i class="fas fa-plus me-1"></i>Add Expense</a>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" name="search" class="form-control" placeholder="Search..." value="@(Context.Request.Query["search"].ToString())" />
        </div>
    </div>
    <div class="col-md-3">
        <input type="date" name="from" class="form-control" value="@(Context.Request.Query["from"].ToString())" />
    </div>
    <div class="col-md-3">
        <input type="date" name="to" class="form-control" value="@(Context.Request.Query["to"].ToString())" />
    </div>
    <div class="col-md-3">
        <div class="btn-group w-100" role="group">
            <a href="@Url.Action("Index")" class="btn @(string.IsNullOrEmpty(type) ? "btn-primary" : "btn-outline-primary")"><i class="fas fa-coins me-1"></i>Revenue</a>
            <a href="@Url.Action("Index", new { type = "Expense" })" class="btn @(type == "Expense" ? "btn-danger" : "btn-outline-danger")"><i class="fas fa-credit-card me-1"></i>Expenses</a>
        </div>
    </div>
</form>

@if (type == "Expense")
{
    var expenses = Model as IEnumerable<ProjectManagerApp.Models.Expense>;
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover datatable mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Category</th>
                        <th>Reason</th>
                        <th>Project</th>
                        <th>Amount</th>
                        <th>Paid By</th>
                        <th>Method</th>
                        <th style="width:100px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (expenses != null)
                    {
                        @foreach (var e in expenses)
                        {
                            <tr>
                                <td>@e.ExpenseDate.ToShortDateString()</td>
                                <td>@e.ExpenseCategory</td>
                                <td>@e.ExpenseReason</td>
                                <td>@e.Project?.Name</td>
                                <td class="text-danger fw-bold">@e.Amount.ToString("C2")</td>
                                <td>@e.PaidBy</td>
                                <td><span class="badge bg-light text-dark">@e.PaymentMethod</span></td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditExpense" asp-route-id="@e.Id" class="btn btn-outline-primary" title="Edit"><i class="fas fa-edit"></i></a>
                                        <form asp-action="DeleteExpense" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@e.Id" />
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="Delete" onclick="return confirm('Delete this expense?')"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    @if (expenses == null || !expenses.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No expenses found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    var revenues = Model as IEnumerable<ProjectManagerApp.Models.Revenue>;
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover datatable mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Source</th>
                        <th>Reason</th>
                        <th>Project</th>
                        <th>Amount</th>
                        <th>Received By</th>
                        <th>Method</th>
                        <th style="width:100px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (revenues != null)
                    {
                        @foreach (var r in revenues)
                        {
                            <tr>
                                <td>@r.RevenueDate.ToShortDateString()</td>
                                <td>@r.RevenueSource</td>
                                <td>@r.Reason</td>
                                <td>@r.Project?.Name</td>
                                <td class="text-success fw-bold">@r.Amount.ToString("C2")</td>
                                <td>@r.ReceivedBy</td>
                                <td><span class="badge bg-light text-dark">@r.PaymentMethod</span></td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditRevenue" asp-route-id="@r.Id" class="btn btn-outline-primary" title="Edit"><i class="fas fa-edit"></i></a>
                                        <form asp-action="DeleteRevenue" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@r.Id" />
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="Delete" onclick="return confirm('Delete this revenue entry?')"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    @if (revenues == null || !revenues.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No revenue entries found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
